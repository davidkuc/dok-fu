{
  "docs_dir": "docs",
  "source_globs": [
    "**/*.py",
    "**/*.js",
    "**/*.ts",
    "**/*.jsx",
    "**/*.tsx",
    "**/*.go",
    "**/*.rs",
    "**/*.java",
    "**/*.cs",
    "**/*.cpp",
    "**/*.c",
    "**/*.h",
    "**/*.rb",
    "**/*.sh"
  ],
  "exclude_globs": [
    "**/node_modules/**",
    "**/.git/**",
    "**/dist/**",
    "**/build/**",
    "**/__pycache__/**",
    "**/*.min.js",
    "dok-fu/scripts/dokfu/**",
    "docs/**"
  ],
  "pointer_token": "dok-fu",
  "comment_map": {
    ".py":   "#",
    ".js":   "//",
    ".ts":   "//",
    ".jsx":  "//",
    ".tsx":  "//",
    ".go":   "//",
    ".rs":   "//",
    ".java": "//",
    ".cs":   "//",
    ".cpp":  "//",
    ".c":    "//",
    ".h":    "//",
    ".rb":   "#",
    ".sh":   "#"
  },
  "registry_path": "dok-fu/config/tags.registry.json",
  "manifest_path": "docs/.dokfu-manifest.json",
  "dokfu_dir": "dok-fu",
  "output_root": "."
}
